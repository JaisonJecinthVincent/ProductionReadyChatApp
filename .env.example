# Server
PORT=5000
NODE_ENV=production
JWT_SECRET=generate-a-strong-random-string

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# Redis
# For Fly.io: use an external Redis (e.g., Upstash, Redis Cloud)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_CALLBACK_URL=https://your-app.fly.dev/api/auth/oauth/google/callback

# Client URLs (CORS origins)
# For Fly.io: use your fly.dev domain
CLIENT_URL=https://your-app.fly.dev
FRONTEND_URL=https://your-app.fly.dev

# Elasticsearch (Elastic Cloud Serverless)
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_URL=https://your-cluster.es.us-central1.gcp.cloud.es.io:443
ELASTICSEARCH_API_KEY=your_api_key
# Or use username/password for traditional Elasticsearch:
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=your_password

# Queue Admin
QUEUE_ADMIN_KEY=admin123

# Fly.io Deployment Notes:
# 1. Set secrets with: fly secrets set KEY=value
# 2. Example: fly secrets set JWT_SECRET=mysecret MONGODB_URI=mongodb+srv://... REDIS_HOST=...
# 3. Deploy with: fly deploy
# 4. For Redis: Use Upstash (https://upstash.com) or Redis Cloud for free tier
# 5. The app runs two processes via concurrently: cluster.js + message-worker-process.js
