# Server
PORT=5000
NODE_ENV=production
JWT_SECRET=generate-a-strong-random-string

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_CALLBACK_URL=https://your-domain.com/api/auth/oauth/google/callback

# Client URLs (CORS origins)
CLIENT_URL=https://your-frontend.up.railway.app
FRONTEND_URL=https://your-frontend.up.railway.app

# Elasticsearch (Elastic Cloud)
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_URL=https://your-cluster.es.us-central1.gcp.cloud.es.io:443
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_cloud_password

# Queue Admin
QUEUE_ADMIN_KEY=admin123
